{
  "name": "digit-studio",
  "version": "0.1.0",
  "private": true,
  "description": "DiGiT Studio — local run monitoring UI",
  "author": "kpfadnis@us.ibm.com",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "(cd .. && DGT_STUDIO_MODE=dev .venv/bin/python -m fms_dgt.studio.server) & next dev --port 3000",
    "build": "next build",
    "start": "(cd .. && .venv/bin/python -m fms_dgt.studio.server)",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ && stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.2",
    "@carbon/charts-react": "^1.27.2",
    "@carbon/colors": "^11.48.0",
    "@carbon/icons-react": "^11.76.0",
    "@carbon/react": "^1.101.0",
    "@carbon/themes": "^11.69.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@uiw/codemirror-extensions-langs": "^4.23.9",
    "@uiw/react-codemirror": "^4.23.9",
    "d3": "^7.9.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "next": "^16.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-split": "^2.0.14",
    "react-wrap-balancer": "^1.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "@carbon/styles": "^1.101.0"
  }
}
